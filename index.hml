        <div style={{display:'inline-flex',alignItems:'center',gap:'6px',background:'rgba(29,158,117,0.2)',border:'0.5px solid rgba(29,158,117,0.4)',color:'#9FE1CB',fontSize:'11px',fontWeight:500,padding:'5px 12px',borderRadius:'20px',marginBottom:'1.5rem'}}>
