  return (
    <section id="aprender">
      <div className="sec-head">
        <div className="sec-tag">CONTEÚDO EDUCATIVO</div>
        <h2 className="sec-h2">Aprenda do jeito certo, no seu ritmo</h2>
        <p className="sec-sub">4 trilhas completas com artigos, vídeos, calculadoras e quizzes.</p>
      </div>
      <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fit,minmax(200px,1fr))',gap:'10px'}}>
        {trilhas.map(t=>(
          <div key={t.num} style={{background:t.bg,borderRadius:'var(--radius-md)',padding:'1.25rem',position:'relative',overflow:'hidden'}}>
            <div style={{position:'absolute',top:'.5rem',right:'.75rem',fontFamily:'Syne,sans-serif',fontSize:'36px',fontWeight:800,opacity:.12,color:t.tC,lineHeight:1}}>{t.num}</div>
            <span style={{display:'inline-block',background:t.tagBg,color:t.tagC,fontSize:'10px',fontWeight:500,padding:'3px 9px',borderRadius:'20px',marginBottom:'.75rem'}}>{t.tag}</span>
            <div style={{fontSize:'14px',fontWeight:500,color:t.tC,marginBottom:'.375rem'}}>{t.title}</div>
            <div style={{fontSize:'12px',lineHeight:1.55,color:t.dC,marginBottom:'.75rem',opacity:.85}}>{t.desc}</div>
            <div style={{fontSize:'11px',fontWeight:500,color:t.mC,opacity:.75}}>{t.meta}</div>
          </div>
        ))}
      </div>
    </section>
  )
}
