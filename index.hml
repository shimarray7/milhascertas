# ─── components/Calculadora.jsx ───────────────────────────────────────────────
cat > components/Calculadora.jsx << 'EOF'
import { useState } from 'react'
const PROGRAMAS=[{label:'Smiles',taxa:.028},{label:'Latam Pass',taxa:.030},{label:'TudoAzul',taxa:.025},{label:'Livelo',taxa:.022},{label:'Esfera',taxa:.032}]
export default function Calculadora() {
  const [qtd,setQtd]=useState(80000)
  const [progIdx,setProgIdx]=useState(0)
  const prog=PROGRAMAS[progIdx]
  const valor=Math.round(qtd*prog.taxa)
  const mult=(prog.taxa/.02).toFixed(1)
  const rec=prog.taxa>=.028?'Resgatar agora':'Aguardar promoção'
  return (
    <section id="calculadora" style={{background:'var(--gray-100)',borderRadius:'var(--radius-xl)',padding:'2.5rem 2rem'}}>
      <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'2.5rem',alignItems:'center'}}>
        <div>
          <div className="sec-tag" style={{textAlign:'left'}}>CALCULADORA</div>
          <h2 style={{fontFamily:'Syne,sans-serif',fontSize:'1.3rem',fontWeight:700,color:'var(--gray-900)',margin:'.5rem 0'}}>Quanto valem suas milhas?</h2>
          <p style={{fontSize:'13px',color:'var(--gray-500)',lineHeight:1.65,marginBottom:'1.5rem'}}>Simule o valor real antes de resgatar ou transferir.</p>
          <div style={{marginBottom:'1rem'}}>
            <label style={{display:'block',fontSize:'11px',fontWeight:500,color:'var(--gray-500)',marginBottom:'4px',textTransform:'uppercase',letterSpacing:'.04em'}}>Quantidade de milhas</label>
            <input type="number" value={qtd} step={5000} min={1000} onChange={e=>setQtd(Number(e.target.value))}/>
          </div>
          <div>
            <label style={{display:'block',fontSize:'11px',fontWeight:500,color:'var(--gray-500)',marginBottom:'4px',textTransform:'uppercase',letterSpacing:'.04em'}}>Programa</label>
            <select value={progIdx} onChange={e=>setProgIdx(Number(e.target.value))}>
              {PROGRAMAS.map((p,i)=><option key={p.label} value={i}>{p.label} — R$ {p.taxa.toFixed(3)}/milha</option>)}
            </select>
          </div>
        </div>
        <div style={{background:'#fff',borderRadius:'var(--radius-md)',padding:'1.5rem',border:'.5px solid var(--border)'}}>
          <div style={{fontSize:'11px',fontWeight:500,color:'var(--gray-500)',textTransform:'uppercase',letterSpacing:'.06em',marginBottom:'.5rem'}}>Valor estimado</div>
          <div style={{fontFamily:'Syne,sans-serif',fontSize:'2.4rem',fontWeight:800,color:'var(--green-700)',lineHeight:1,marginBottom:'4px'}}>R$ {valor.toLocaleString('pt-BR')}</div>
          <div style={{fontSize:'12px',color:'var(--gray-500)',marginBottom:'1.25rem'}}>{prog.label} · {qtd.toLocaleString('pt-BR')} milhas</div>
          {[['Valor por milha',`R$ ${prog.taxa.toFixed(3)}`],['Vs. comprar direto',`~${mult}x mais barato`],['Recomendação',rec],['Total estimado',`R$ ${valor.toLocaleString('pt-BR')}`]].map(([k,v],i,arr)=>(
            <div key={k} style={{display:'flex',justifyContent:'space-between',fontSize:'12px',padding:'7px 0',borderBottom:i<arr.length-1?'.5px solid var(--border)':'none',color:'var(--gray-500)'}}>
              <span>{k}</span>
              <span style={{color:k==='Total estimado'?'var(--green-700)':'var(--gray-900)',fontWeight:500}}>{v}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
EOF

