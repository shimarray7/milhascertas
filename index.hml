#!/bin/bash
# MilhasCertas — Script de criação automática de todos os arquivos
# Cole este script inteiro no terminal do github.dev e pressione Enter

mkdir -p components pages/api styles lib

# ─── package.json ─────────────────────────────────────────────────────────────
cat > package.json << 'EOF'
{
  "name": "milhascertas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start"
  },
  "dependencies": {
    "next": "14.2.3",
    "react": "^18",
    "react-dom": "^18",
    "@supabase/supabase-js": "^2.43.0"
  }
}
EOF

