    <section style={{background:'var(--green-900)',borderRadius:'var(--radius-xl)',padding:'3.5rem 2.5rem',marginBottom:'1.25rem',display:'flex',alignItems:'flex-start',justifyContent:'space-between',gap:'2rem',flexWrap:'wrap'}}>
