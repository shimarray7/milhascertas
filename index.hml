  {id:'bradesco',sig:'BR',name:'Bradesco Prime',type:'Cartão premium',cat:'cartao',rating:'4.0',bg:'#FCEBEB',c:'#791F1F',desc:'Acúmulo de pontos Livelo, acesso a salas VIP e assistência em viagens internacionais.',url:'https://banco.bradesco/cartoes'},
