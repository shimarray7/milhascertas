# ─── styles/globals.css ───────────────────────────────────────────────────────
cat > styles/globals.css << 'EOF'
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;700;800&family=DM+Sans:wght@300;400;500&display=swap');
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:#fff;color:#1a1a1a;line-height:1.6;-webkit-font-smoothing:antialiased}
:root{
  --green-900:#04342C;--green-800:#085041;--green-700:#0F6E56;--green-600:#1D9E75;
  --green-400:#5DCAA5;--green-200:#9FE1CB;--green-100:#E1F5EE;
  --amber-400:#BA7517;--amber-100:#FAEEDA;--amber-700:#633806;
  --blue-800:#0C447C;--blue-100:#E6F1FB;
  --purple-800:#3C3489;--purple-100:#EEEDFE;
  --gray-900:#1a1a1a;--gray-700:#444441;--gray-500:#5F5E5A;--gray-300:#B4B2A9;--gray-100:#F1EFE8;
  --border:rgba(0,0,0,0.10);--border-strong:rgba(0,0,0,0.20);
  --radius-sm:8px;--radius-md:12px;--radius-lg:16px;--radius-xl:20px;
}
.main-wrapper{max-width:1000px;margin:0 auto;padding:1.5rem 1.5rem 3rem}
section{margin-bottom:4rem}
.sec-head{text-align:center;margin-bottom:2rem}
.sec-tag{display:inline-block;background:var(--green-100);color:var(--green-800);font-size:11px;font-weight:500;padding:4px 12px;border-radius:20px;margin-bottom:.75rem;letter-spacing:.06em;text-transform:uppercase}
.sec-h2{font-family:'Syne',sans-serif;font-size:clamp(1.4rem,3vw,1.8rem);font-weight:700;color:var(--gray-900);margin-bottom:.5rem;letter-spacing:-.02em}
.sec-sub{font-size:14px;color:var(--gray-500);line-height:1.65;max-width:480px;margin:0 auto}
.card{background:#fff;border:.5px solid var(--border);border-radius:var(--radius-md);padding:1.25rem;transition:border-color .15s}
.card:hover{border-color:var(--border-strong)}
.grid-2{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:12px}
.grid-3{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px}
input[type="email"],input[type="number"],select{font-family:'DM Sans',sans-serif;font-size:13px;padding:9px 12px;border-radius:var(--radius-sm);border:.5px solid var(--border-strong);background:#fff;color:var(--gray-900);width:100%;outline:none;transition:border-color .15s}
input:focus,select:focus{border-color:var(--green-600);box-shadow:0 0 0 3px rgba(29,158,117,.12)}
@media(max-width:640px){.main-wrapper{padding:1rem 1rem 2rem}section{margin-bottom:2.5rem}}
EOF

