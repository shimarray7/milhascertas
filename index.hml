export default function TrustBar() {
  const items=[{icon:'✓',bg:'#E1F5EE',c:'#085041',text:'Parceiros verificados manualmente'},{icon:'↗',bg:'#E6F1FB',c:'#0C447C',text:'Links diretos para sites oficiais'},{icon:'0',bg:'#FAEEDA',c:'#633806',text:'Sem cadastro para explorar'},{icon:'★',bg:'#EEEDFE',c:'#3C3489',text:'Conteúdo educativo completo'}]
  return (
    <div style={{display:'flex',alignItems:'center',justifyContent:'center',gap:'1.25rem',padding:'1rem 1.5rem',border:'0.5px solid var(--border)',borderRadius:'var(--radius-md)',marginBottom:'1.25rem',flexWrap:'wrap'}}>
      {items.map((it,i)=>(
        <div key={i} style={{display:'flex',alignItems:'center',gap:'7px',fontSize:'12px',color:'var(--gray-500)'}}>
          <span style={{width:'18px',height:'18px',borderRadius:'5px',background:it.bg,color:it.c,display:'flex',alignItems:'center',justifyContent:'center',fontSize:'10px',fontWeight:500}}>{it.icon}</span>
          {it.text}
        </div>
      ))}
    </div>
  )
}
EOF

