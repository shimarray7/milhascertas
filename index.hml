            <div style={{fontFamily:'Syne,sans-serif',fontSize:'2rem',fontWeight:800,color:'var(--green-700)',margin:'.5rem 0 2px'}}>{pl.price}</div>
            <div style={{fontSize:'11px',color:'var(--gray-500)',marginBottom:'1rem'}}>{pl.period}</div>
            <div style={{height:'.5px',background:'var(--border)',marginBottom:'1rem'}}/>
            {pl.feats.map((f,i)=>(
              <div key={i} style={{display:'flex',alignItems:'center',gap:'7px',fontSize:'12px',color:'var(--gray-500)',padding:'4px 0'}}>
                <div style={{width:'14px',height:'14px',borderRadius:'4px',background:f.ok?'#E1F5EE':'#F1EFE8',color:f.ok?'#085041':'#B4B2A9',display:'flex',alignItems:'center',justifyContent:'center',fontSize:'9px',fontWeight:500}}>{f.ok?'✓':'—'}</div>
                {f.t}
              </div>
            ))}
            <button style={{width:'100%',marginTop:'1.25rem',padding:'10px',borderRadius:'9px',fontSize:'13px',fontWeight:500,cursor:'pointer',fontFamily:'DM Sans,sans-serif',background:pl.primary?'var(--green-700)':'transparent',color:pl.primary?'#fff':'var(--gray-900)',border:pl.primary?'none':'.5px solid var(--border-strong)'}}>
              {pl.btn}
            </button>
          </div>
        ))}
      </div>
    </section>
  )
}
