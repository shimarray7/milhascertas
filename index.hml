  {id:'inter',sig:'IN',name:'Banco Inter',type:'Banco digital',cat:'banco',rating:'4.3',bg:'#FAEEDA',c:'#633806',desc:'Inter Loop com pontos sem expiração e cashback em compras no Inter Shop.',url:'https://www.inter.co'},
  {id:'passaport',sig:'PA',name:'Passaport',type:'Gestão e resgate',cat:'resgate',rating:'4.1',bg:'#E1F5EE',c:'#085041',desc:'Consolida saldo de múltiplos programas e ajuda a encontrar as melhores oportunidades.',url:'https://www.passaport.com.br'},
]
export default function Partners() {
  const [active,setActive]=useState('todos')
  const filtered=active==='todos'?PARTNERS:PARTNERS.filter(p=>p.cat===active)
  return (
    <section id="parceiros">
      <div className="sec-head">
        <div className="sec-tag">PARCEIROS VERIFICADOS</div>
        <h2 className="sec-h2">Os melhores do mercado, curados para você</h2>
        <p className="sec-sub">Apenas parceiros confiáveis. Filtre por categoria e acesse o site oficial com um clique.</p>
      </div>
      <div style={{display:'flex',gap:'6px',marginBottom:'1.25rem',flexWrap:'wrap'}}>
        {CATS.map(c=>(
          <button key={c.id} onClick={()=>setActive(c.id)} style={{background:active===c.id?'var(--green-700)':'#F1EFE8',border:active===c.id?'0.5px solid var(--green-700)':'0.5px solid var(--border)',borderRadius:'20px',padding:'5px 14px',fontSize:'12px',fontFamily:'DM Sans,sans-serif',color:active===c.id?'#fff':'var(--gray-500)',cursor:'pointer'}}>
            {c.label}
          </button>
        ))}
      </div>
      <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fill,minmax(210px,1fr))',gap:'10px'}}>
        {filtered.map(p=>(
          <div key={p.id} style={{background:'#fff',border:'0.5px solid var(--border)',borderRadius:'var(--radius-md)',padding:'1.1rem'}}>
            <div style={{display:'flex',alignItems:'center',gap:'9px',marginBottom:'.625rem'}}>
              <div style={{width:'34px',height:'34px',borderRadius:'9px',background:p.bg,color:p.c,display:'flex',alignItems:'center',justifyContent:'center',fontSize:'11px',fontWeight:500,flexShrink:0}}>{p.sig}</div>
              <div>
                <div style={{fontSize:'13px',fontWeight:500,color:'var(--gray-900)'}}>{p.name}</div>
                <div style={{fontSize:'10px',color:'var(--gray-500)'}}>{p.type}</div>
              </div>
            </div>
            <p style={{fontSize:'11.5px',color:'var(--gray-500)',lineHeight:1.55,marginBottom:'.75rem'}}>{p.desc}</p>
            <div style={{display:'flex',alignItems:'center',justifyContent:'space-between'}}>
              <span style={{fontSize:'11px',color:'var(--amber-400)',fontWeight:500}}>★ {p.rating}</span>
              <a href={p.url} target="_blank" rel="noopener noreferrer" style={{fontSize:'11px',fontWeight:500,padding:'5px 11px',borderRadius:'7px',border:'0.5px solid var(--green-600)',color:'var(--green-700)',background:'transparent',textDecoration:'none'}}>Acessar site →</a>
            </div>
          </div>
        ))}
      </div>
    </section>
  )
}
EOF

