# ─── components/CtaFinal.jsx ──────────────────────────────────────────────────
cat > components/CtaFinal.jsx << 'EOF'
import { useState } from 'react'
export default function CtaFinal() {
  const [email,setEmail]=useState('')
  const [status,setStatus]=useState('idle')
  const [msg,setMsg]=useState('')
  async function handleSubmit(e) {
    e.preventDefault()
    if(!email||!email.includes('@'))return
    setStatus('loading')
    try {
      const res=await fetch('/api/waitlist',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email})})
      const data=await res.json()
      if(res.ok){setStatus('success');setMsg(data.message||'Você será avisado no lançamento!')}
      else{setStatus('error');setMsg(data.error||'Algo deu errado. Tente novamente.')}
    } catch{setStatus('error');setMsg('Erro de conexão. Tente novamente.')}
  }
  return (
    <section id="cta" style={{background:'var(--green-900)',borderRadius:'var(--radius-xl)',padding:'3rem 2.5rem',textAlign:'center'}}>
      <h2 style={{fontFamily:'Syne,sans-serif',fontSize:'clamp(1.4rem,3vw,1.9rem)',fontWeight:800,color:'#fff',marginBottom:'.75rem',lineHeight:1.2}}>
        Pronto para acumular milhas <em style={{color:'var(--green-400)',fontStyle:'normal'}}>de verdade?</em>
      </h2>
      <p style={{fontSize:'14px',color:'rgba(255,255,255,0.6)',marginBottom:'1.75rem',lineHeight:1.6}}>
        Entre na lista e seja um dos primeiros a acessar o MilhasCertas. É grátis.
      </p>
      {status==='success'?(
        <p style={{color:'var(--green-400)',fontSize:'15px',fontWeight:500}}>{msg}</p>
      ):(
        <form onSubmit={handleSubmit} style={{display:'flex',gap:'8px',maxWidth:'420px',margin:'0 auto .75rem'}}>
          <input type="email" placeholder="seu@email.com" value={email} onChange={e=>setEmail(e.target.value)} disabled={status==='loading'} style={{flex:1,fontSize:'13px',padding:'10px 14px',borderRadius:'9px',border:'.5px solid rgba(255,255,255,0.2)',background:'rgba(255,255,255,0.1)',color:'#fff',outline:'none',width:'auto'}} required/>
          <button type="submit" disabled={status==='loading'} style={{background:'var(--green-600)',color:'#fff',fontSize:'13px',fontWeight:500,padding:'10px 18px',borderRadius:'9px',border:'none',cursor:'pointer',fontFamily:'DM Sans,sans-serif',whiteSpace:'nowrap',opacity:status==='loading'?.7:1}}>
            {status==='loading'?'Aguarde...':'Quero acesso'}
          </button>
        </form>
      )}
      {status==='error'&&<p style={{color:'#F09595',fontSize:'12px',marginTop:'.5rem'}}>{msg}</p>}
      <p style={{fontSize:'11px',color:'rgba(255,255,255,0.3)',marginTop:'.5rem'}}>Sem spam. Cancele quando quiser.</p>
    </section>
  )
}
EOF

