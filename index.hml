          <div style={{display:'flex'}}>
            {avatars.map((a,i)=>(
              <div key={a.i} style={{width:'30px',height:'30px',borderRadius:'50%',border:'2px solid var(--green-900)',background:a.bg,color:a.c,display:'flex',alignItems:'center',justifyContent:'center',fontSize:'10px',fontWeight:500,marginLeft:i===0?0:'-8px'}}>{a.i}</div>
            ))}
