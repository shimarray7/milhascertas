        <meta name="description" content="Hub de milhas com parceiros verificados, conteúdo educativo e ferramentas para maximizar seus pontos." />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
      </Head>
      <main className="main-wrapper">
        <Navbar /><Hero /><TrustBar /><HowItWorks /><Partners />
